                        <Text profile="fs25_multiTextOptionText" name="text" />
                    </MultiTextOption>

                    <Text profile="taskListIntroText" text="$l10n_ui_set_task_start_period" position="-380px 276px" size="360px 22px" />
                    <MultiTextOption profile="fs25_subCategorySelectorTabbed" id="startPeriodOption" position="40px 276px" size="480px 44px" onClick="onStartPeriodChange">
                        <Text profile="fs25_multiTextOptionText" name="text" />
                    </MultiTextOption>

                    <Text profile="taskListIntroText" text="$l10n_ui_set_task_period" position="-380px 322px" size="360px 22px" />
                    <MultiTextOption profile="fs25_subCategorySelectorTabbed" id="periodOption" position="40px 322px" size="480px 44px" onClick="onPeriodChange">
                        <Text profile="fs25_multiTextOptionText" name="text" />
                    </MultiTextOption>
                </GuiElement>

                <GuiElement id="linkedSection" position="0px 52px">
                    <GuiElement id="husbandryPickRow" position="0px 0px">
