                    </GuiElement>
                </GuiElement>
            </GuiElement>
        </GuiElement>
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonOK" text="$l10n_ui_btn_ok" onClick="onClickSave" />
            <Button profile="buttonBack" text="$l10n_ui_btn_close" onClick="onClickCancel" />
        </BoxLayout>
    </GuiElement>
</GUI>
