                        <Text profile="taskListIntroText" text="$l10n_ui_task_request_production_type" position="-380px 46px" size="360px 22px" />
                        <MultiTextOption profile="fs25_subCategorySelectorTabbed" id="productionIoOption" position="40px 46px" size="480px 44px" onClick="onProductionIoChange">
                            <Text profile="fs25_multiTextOptionText" name="text" />
