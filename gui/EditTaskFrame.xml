<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />
    <GuiElement profile="dialogBg" id="dialogElement" size="920px 820px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle" />
        <ThreePartBitmap profile="fs25_dialogBgTop" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />
        <GuiElement profile="fs25_dialogContentContainer">
            <Animation profile="fs25_dialogLoading" id="iconLoadingElement" />
            <Text profile="dialogTitle" id="titleText" text="$l10n_ui_edit_task" position="0px -28px" />

            <GuiElement id="formRoot" position="0px -62px" size="880px 620px">
                <GuiElement id="taskTypeRow" position="0px 0px">
                    <Text profile="taskListIntroText" id="taskTypeHint" text="$l10n_ui_task_request_type_description" position="-380px 6px" size="360px 36px" />
                    <MultiTextOption profile="fs25_subCategorySelectorTabbed" id="taskTypeOption" position="40px 0px" size="480px 44px" onClick="onTaskTypeChange">
                        <Text profile="fs25_multiTextOptionText" name="text" />
                    </MultiTextOption>
                </GuiElement>

                <GuiElement id="standardSection" position="0px 52px">
                    <Text profile="taskListIntroText" text="$l10n_ui_set_task_detail" position="-380px 0px" size="360px 22px" />
                    <TextInput profile="fs25_textInput" id="taskDetailInput" position="40px 0px" size="480px 40px" />

                    <Text profile="taskListIntroText" text="$l10n_ui_set_task_effort" position="-380px 46px" size="360px 22px" />
